# ─────────────────────────────────────────────────────
#  server/.dockerignore
#  Prevents unnecessary files from being sent to Docker
#  build context — keeps images lean and builds fast.
# ─────────────────────────────────────────────────────

# Dependencies – reinstalled inside container
node_modules/

# Compiled output – rebuilt inside container
dist/

# Local environment files – injected via docker-compose.yml
.env
.env.*

# Logs
*.log
npm-debug.log*

# Editor / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Test files
*.test.ts
*.spec.ts
