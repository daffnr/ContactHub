# ──────────────────────────────────────────────────────────────
#  .env.example  –  Template for Docker Compose environment
#
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in strong passwords in .env
#    3. NEVER commit .env to git
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=contact_app
POSTGRES_USER=contactuser
POSTGRES_PASSWORD=change_me_user_password

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_string
