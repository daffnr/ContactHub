# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=contact_app
MYSQL_USER=contactuser
MYSQL_PASSWORD=change_me_user_password

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_string
